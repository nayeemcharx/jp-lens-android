*.iml
.gradle
/local.properties
/.idea/caches
/.idea/libraries
/.idea/modules.xml
/.idea/workspace.xml
/.idea/navEditor.xml
/.idea/assetWizardSettings.xml
.DS_Store
/build
/captures
.externalNativeBuild
.cxx
local.properties

# Generated/large app assets (jmdict.db, fugumt/, tutorial videos, etc.) — built by scripts/, not committed.
/app/src/main/assets/

# Release build output (AAB, baseline profiles, metadata).
/app/release/

# Debug-only e2e test fixtures — ignore everything except the fixture source + its README
# (the manifest and the smoke-test PNG are excluded; kept out of git status/tracking).
/app/src/debug/*
!/app/src/debug/java/
/app/src/debug/java/*
!/app/src/debug/java/com/
/app/src/debug/java/com/*
!/app/src/debug/java/com/nayeemcharx/
/app/src/debug/java/com/nayeemcharx/*
!/app/src/debug/java/com/nayeemcharx/jplens/
/app/src/debug/java/com/nayeemcharx/jplens/*
!/app/src/debug/java/com/nayeemcharx/jplens/e2e/
/app/src/debug/java/com/nayeemcharx/jplens/e2e/*
!/app/src/debug/java/com/nayeemcharx/jplens/e2e/E2eFixtureActivity.kt
!/app/src/debug/assets/
/app/src/debug/assets/*
!/app/src/debug/assets/e2e/
/app/src/debug/assets/e2e/*
!/app/src/debug/assets/e2e/README.md

# Build/tooling scripts dir — keeps scratch outputs (__pycache__, generated userdict build files)
# out of git status without affecting already-tracked scripts.
/scripts/

# Generated Anki decks (built by scripts/build_anki_apkg.py).
/*.apkg

# Release signing — never commit the keystore or its credentials.
*.jks
*.keystore
/app/keystore.properties

# Claude Code local settings / scratch — machine-specific, not shared.
/.claude/
